{
  "name": "workspace-session-terminals",
  "displayName": "Workspace Session Terminals",
  "description": "Manage workspace terminals, zellij sessions, and tmux sessions from the VS Code sidebar.",
  "version": "0.0.5",
  "publisher": "843773493",
  "license": "MIT",
  "icon": "resources/marketplace-icon.png",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/843773493/vscode-terminal-manager.git"
  },
  "bugs": {
    "url": "https://github.com/843773493/vscode-terminal-manager/issues"
  },
  "homepage": "https://github.com/843773493/vscode-terminal-manager#readme",
  "galleryBanner": {
    "color": "#0E6F70",
    "theme": "dark"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "Workspace Session Terminals starts and attaches to tmux/zellij shell sessions, so the workspace must be trusted before those commands run."
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "Workspace Session Terminals requires a real local or remote shell with tmux or zellij available."
    }
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "tmux",
    "zellij",
    "workspace",
    "remote"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:workspaceSessionTerminals.workspace",
    "onView:workspaceSessionTerminals.zellij",
    "onView:workspaceSessionTerminals.tmux",
    "onCommand:workspace-session-terminals.openSidebar",
    "onCommand:workspace-session-terminals.refreshAll",
    "onCommand:workspace-session-terminals.dumpState",
    "onCommand:workspace-session-terminals.emitTestLog"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "workspace-session-terminals.openSidebar",
        "title": "打开终端管理器",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.refreshAll",
        "title": "刷新全部终端状态",
        "category": "Workspace Session Terminals",
        "icon": {
          "light": "resources/light/refresh.svg",
          "dark": "resources/dark/refresh.svg"
        }
      },
      {
        "command": "workspace-session-terminals.dumpState",
        "title": "导出终端管理器状态",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.emitTestLog",
        "title": "写入终端管理器测试日志",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.workspace.create",
        "title": "新建 Tmux/Zellij 终端",
        "category": "Workspace Session Terminals",
        "icon": {
          "light": "resources/light/plus.svg",
          "dark": "resources/dark/plus.svg"
        }
      },
      {
        "command": "workspace-session-terminals.workspace.refresh",
        "title": "刷新会话终端",
        "category": "Workspace Session Terminals",
        "icon": {
          "light": "resources/light/refresh.svg",
          "dark": "resources/dark/refresh.svg"
        }
      },
      {
        "command": "workspace-session-terminals.workspace.toggleAutoSave",
        "title": "切换自动记住会话终端",
        "category": "Workspace Session Terminals",
        "icon": "$(sync)"
      },
      {
        "command": "workspace-session-terminals.workspace.show",
        "title": "显示会话终端",
        "category": "Workspace Session Terminals",
        "icon": "$(debug-start)"
      },
      {
        "command": "workspace-session-terminals.workspace.kill",
        "title": "关闭会话终端",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.zellij.new",
        "title": "新建 Zellij 会话",
        "category": "Workspace Session Terminals",
        "icon": {
          "light": "resources/light/plus.svg",
          "dark": "resources/dark/plus.svg"
        }
      },
      {
        "command": "workspace-session-terminals.zellij.attach",
        "title": "附加到 Zellij 会话",
        "category": "Workspace Session Terminals",
        "icon": "$(debug-start)"
      },
      {
        "command": "workspace-session-terminals.zellij.rename",
        "title": "重命名 Zellij 会话",
        "category": "Workspace Session Terminals",
        "icon": "$(edit)"
      },
      {
        "command": "workspace-session-terminals.zellij.kill",
        "title": "结束 Zellij 会话",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.zellij.delete",
        "title": "删除 Zellij 会话",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.zellij.refresh",
        "title": "刷新 Zellij 会话",
        "category": "Workspace Session Terminals",
        "icon": {
          "light": "resources/light/refresh.svg",
          "dark": "resources/dark/refresh.svg"
        }
      },
      {
        "command": "workspace-session-terminals.zellij.toggleAutoRefresh",
        "title": "切换 Zellij 自动刷新",
        "category": "Workspace Session Terminals",
        "icon": "$(sync)"
      },
      {
        "command": "workspace-session-terminals.tmux.new",
        "title": "新建 Tmux 会话",
        "category": "Workspace Session Terminals",
        "icon": {
          "light": "resources/light/plus.svg",
          "dark": "resources/dark/plus.svg"
        }
      },
      {
        "command": "workspace-session-terminals.tmux.attach",
        "title": "附加到 Tmux 目标",
        "category": "Workspace Session Terminals",
        "icon": "$(debug-start)"
      },
      {
        "command": "workspace-session-terminals.tmux.rename",
        "title": "重命名 Tmux 会话",
        "category": "Workspace Session Terminals",
        "icon": "$(edit)"
      },
      {
        "command": "workspace-session-terminals.tmux.renameWindow",
        "title": "重命名 Tmux 窗口",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.tmux.newWindow",
        "title": "新建 Tmux 窗口",
        "category": "Workspace Session Terminals",
        "icon": {
          "light": "resources/light/plus.svg",
          "dark": "resources/dark/plus.svg"
        }
      },
      {
        "command": "workspace-session-terminals.tmux.killSession",
        "title": "结束 Tmux 会话",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.tmux.killWindow",
        "title": "结束 Tmux 窗口",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.tmux.killPane",
        "title": "结束 Tmux 面板",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.tmux.splitPaneRight",
        "title": "向右拆分 Tmux 面板",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.tmux.splitPaneDown",
        "title": "向下拆分 Tmux 面板",
        "category": "Workspace Session Terminals"
      },
      {
        "command": "workspace-session-terminals.tmux.refresh",
        "title": "刷新 Tmux 会话",
        "category": "Workspace Session Terminals",
        "icon": {
          "light": "resources/light/refresh.svg",
          "dark": "resources/dark/refresh.svg"
        }
      },
      {
        "command": "workspace-session-terminals.tmux.toggleAutoRefresh",
        "title": "切换 Tmux 自动刷新",
        "category": "Workspace Session Terminals",
        "icon": "$(sync)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "workspaceSessionTerminals",
          "title": "Workspace Session Terminals",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "workspaceSessionTerminals": [
        {
          "id": "workspaceSessionTerminals.workspace",
          "name": "工作区终端管理"
        },
        {
          "id": "workspaceSessionTerminals.zellij",
          "name": "Zellij 管理"
        },
        {
          "id": "workspaceSessionTerminals.tmux",
          "name": "Tmux 管理"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "workspace-session-terminals.workspace.create",
          "when": "view == workspaceSessionTerminals.workspace",
          "group": "navigation@1"
        },
        {
          "command": "workspace-session-terminals.workspace.refresh",
          "when": "view == workspaceSessionTerminals.workspace",
          "group": "navigation@2"
        },
        {
          "command": "workspace-session-terminals.workspace.toggleAutoSave",
          "when": "view == workspaceSessionTerminals.workspace",
          "group": "1_settings"
        },
        {
          "command": "workspace-session-terminals.zellij.new",
          "when": "view == workspaceSessionTerminals.zellij",
          "group": "navigation@1"
        },
        {
          "command": "workspace-session-terminals.zellij.refresh",
          "when": "view == workspaceSessionTerminals.zellij",
          "group": "navigation@2"
        },
        {
          "command": "workspace-session-terminals.zellij.toggleAutoRefresh",
          "when": "view == workspaceSessionTerminals.zellij",
          "group": "1_settings"
        },
        {
          "command": "workspace-session-terminals.tmux.new",
          "when": "view == workspaceSessionTerminals.tmux",
          "group": "navigation@1"
        },
        {
          "command": "workspace-session-terminals.tmux.refresh",
          "when": "view == workspaceSessionTerminals.tmux",
          "group": "navigation@2"
        },
        {
          "command": "workspace-session-terminals.tmux.toggleAutoRefresh",
          "when": "view == workspaceSessionTerminals.tmux",
          "group": "1_settings"
        }
      ],
      "view/item/context": [
        {
          "command": "workspace-session-terminals.workspace.show",
          "when": "view == workspaceSessionTerminals.workspace && viewItem == workspaceTerminalOpen",
          "group": "inline@1"
        },
        {
          "command": "workspace-session-terminals.workspace.kill",
          "when": "view == workspaceSessionTerminals.workspace && viewItem == workspaceTerminalOpen",
          "group": "2_destructive"
        },
        {
          "command": "workspace-session-terminals.zellij.attach",
          "when": "view == workspaceSessionTerminals.zellij && viewItem == zellijSession",
          "group": "inline@1"
        },
        {
          "command": "workspace-session-terminals.zellij.rename",
          "when": "view == workspaceSessionTerminals.zellij && viewItem == zellijSession",
          "group": "1_modification"
        },
        {
          "command": "workspace-session-terminals.zellij.kill",
          "when": "view == workspaceSessionTerminals.zellij && viewItem == zellijSession",
          "group": "2_destructive@1"
        },
        {
          "command": "workspace-session-terminals.zellij.delete",
          "when": "view == workspaceSessionTerminals.zellij && viewItem == zellijSession",
          "group": "2_destructive@2"
        },
        {
          "command": "workspace-session-terminals.tmux.attach",
          "when": "view == workspaceSessionTerminals.tmux && (viewItem == tmuxSession || viewItem == tmuxWindow || viewItem == tmuxPane)",
          "group": "inline@1"
        },
        {
          "command": "workspace-session-terminals.tmux.newWindow",
          "when": "view == workspaceSessionTerminals.tmux && viewItem == tmuxSession",
          "group": "inline@2"
        },
        {
          "command": "workspace-session-terminals.tmux.splitPaneRight",
          "when": "view == workspaceSessionTerminals.tmux && viewItem == tmuxPane",
          "group": "inline@2"
        },
        {
          "command": "workspace-session-terminals.tmux.rename",
          "when": "view == workspaceSessionTerminals.tmux && viewItem == tmuxSession",
          "group": "1_modification"
        },
        {
          "command": "workspace-session-terminals.tmux.renameWindow",
          "when": "view == workspaceSessionTerminals.tmux && viewItem == tmuxWindow",
          "group": "1_modification"
        },
        {
          "command": "workspace-session-terminals.tmux.splitPaneDown",
          "when": "view == workspaceSessionTerminals.tmux && viewItem == tmuxPane",
          "group": "1_modification"
        },
        {
          "command": "workspace-session-terminals.tmux.killSession",
          "when": "view == workspaceSessionTerminals.tmux && viewItem == tmuxSession",
          "group": "2_destructive"
        },
        {
          "command": "workspace-session-terminals.tmux.killWindow",
          "when": "view == workspaceSessionTerminals.tmux && viewItem == tmuxWindow",
          "group": "2_destructive"
        },
        {
          "command": "workspace-session-terminals.tmux.killPane",
          "when": "view == workspaceSessionTerminals.tmux && viewItem == tmuxPane",
          "group": "2_destructive"
        }
      ]
    },
    "configuration": {
      "title": "Workspace Session Terminals",
      "properties": {
        "workspaceSessionTerminals.autoAttachRememberedTerminals": {
          "type": "boolean",
          "default": true,
          "description": "Attach remembered tmux and zellij workspace terminals automatically when the workspace is opened."
        },
        "workspaceSessionTerminals.autoSaveIntervalMs": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "description": "How often remembered tmux and zellij terminal state is saved."
        },
        "workspaceSessionTerminals.autoRefreshIntervalMs": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "description": "How often tmux and zellij session trees are refreshed."
        },
        "workspaceSessionTerminals.logToOutput": {
          "type": "boolean",
          "default": true,
          "description": "Mirror extension diagnostics into the VS Code Output channel."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package:vsix": "npx --yes @vscode/vsce package --out dist/workspace-session-terminals-0.0.5.vsix",
    "start": "node scripts/open-dev-host.mjs",
    "open:dev": "node scripts/open-dev-host.mjs",
    "e2e": "node scripts/run-e2e.mjs",
    "e2e:trace": "node scripts/run-e2e.mjs trace",
    "e2e:debug": "node scripts/run-e2e.mjs debug",
    "artifacts:latest": "node scripts/inspect-latest-run.mjs",
    "clean": "node scripts/clean.mjs build",
    "clean:artifacts": "node scripts/clean.mjs artifacts",
    "clean:cache": "node scripts/clean.mjs cache",
    "clean:all": "node scripts/clean.mjs all"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.101.0",
    "@wdio/cli": "9.29.1",
    "@wdio/devtools-service": "10.6.1",
    "@wdio/globals": "9.29.1",
    "@wdio/json-reporter": "9.29.1",
    "@wdio/logger": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/protocols": "9.28.0",
    "@wdio/spec-reporter": "9.29.1",
    "expect-webdriverio": "5.6.9",
    "typescript": "^5.8.3",
    "wdio-vscode-service": "8.0.0",
    "webdriverio": "9.29.1"
  }
}
